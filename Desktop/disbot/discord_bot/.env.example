# ── Modèle de configuration ──────────────────────────────────────────────
# Copie ce fichier en « .env » et remplis tes vraies valeurs.
# Le vrai .env ne doit JAMAIS être partagé (il contient le token secret).

# Token du bot (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=colle_ton_token_ici

# ID de ton serveur Discord (clic droit sur le serveur → Copier l'identifiant)
GUILD_ID=000000000000000000

# Rôle des membres non encore vérifiés (optionnel)
ROLE_EXTERNE=000000000000000000

# Rôle attribué à tout étudiant vérifié
ROLE_MIV=000000000000000000

# Rôles des groupes TD (un par groupe)
ROLE_TD_1=000000000000000000
ROLE_TD_2=000000000000000000
ROLE_TD_3=000000000000000000

# Rôles des groupes TP (optionnel, si tu les utilises un jour)
ROLE_TP_1=000000000000000000
ROLE_TP_2=000000000000000000

# Lien du Google Sheet (Partager → « Tout le monde avec le lien »)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/XXXXXXXX/edit?gid=0
